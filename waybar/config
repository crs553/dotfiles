    "hyprland/language",
    "hyprland/scratchpad"
  ],

  "modules-center": [
    "hyprland/window",
    "mpris"
  ],

  "modules-right": [
    "idle_inhibitor",
    "custom/power_profile",
    "bluetooth",
    "network",
    "pulseaudio",
    "cpu",
    "memory",
    "disk",
    "temperature",
    "backlight",
    "battery",
    "clock",
    "tray",
    "custom/weather"
